# Environment configuration template. Copy to `.env` for local work, or set these as
# per-environment secrets/variables in CI (see PIPELINE-SETUP.md).
#
# Every VITE_* value is compiled into the PUBLIC browser bundle. Put NOTHING secret here:
#  - The Auth0 client is a public PKCE client and has no client secret.
#  - Backend is SELF-HOSTED PostgREST behind Front Door (no managed Supabase, no GoTrue).
#    VITE_SUPABASE_URL is the Front Door hostname; VITE_SUPABASE_ANON_KEY is only a
#    supabase-js placeholder (PostgREST ignores it — it authorizes on the Auth0 token).
#  - The Postgres service_role must NEVER be set as a VITE_* var — it bypasses RLS.

# One of: local | sit | uat | production
# "local" (also used by the Lovable sandbox) leaves Auth0 optional so the app runs without a
# tenant. sit/uat/production REFUSE TO BUILD unless every value below is set (vite.config.ts).
VITE_APP_ENV=local

# --- Auth0 (Authorization Code + PKCE) --------------------------------------
# Use the tenant's CUSTOM DOMAIN in secured environments so silent token renewal is a
# first-party request (see src/lib/auth.tsx). Host only, no scheme.
VITE_AUTH0_DOMAIN=your-tenant.eu.auth0.com
VITE_AUTH0_CLIENT_ID=your-auth0-spa-client-id
# API identifier of the Auth0 API this app requests tokens for; also the token audience
# Supabase validates against.
VITE_AUTH0_AUDIENCE=https://api.your-app.example.com

# --- Backend (self-hosted PostgREST via Front Door) -------------------------
# Front Door hostname for this environment. supabase-js appends /rest/v1/<table>, which
# Front Door routes to the PostgREST Container App.
VITE_SUPABASE_URL=https://gentlecalc-sit.z01.azurefd.net
# Placeholder only — PostgREST does not read it. Any non-secret string.
VITE_SUPABASE_ANON_KEY=postgrest-ignores-this-apikey-placeholder
